# Choose one provider: openai, gemini, or random.
# random means each generation request randomly uses an available configured provider.
IMAGE_PROVIDER=random

# OpenAI image API
OPENAI_API_KEY=replace-with-your-openai-api-key
OPENAI_IMAGE_MODEL=gpt-image-1.5
OPENAI_FALLBACK_IMAGE_MODEL=gpt-image-1
IMAGE_SIZE=1024x1536
IMAGE_QUALITY=medium
IMAGE_OUTPUT_FORMAT=jpeg

# Gemini image API
GEMINI_API_KEY=replace-with-your-gemini-api-key
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
GEMINI_FALLBACK_IMAGE_MODEL=gemini-2.5-flash-image
