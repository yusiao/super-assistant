# Copy this file to a7-leju-monitor.env and fill in the secrets.

TASK_ID=a7-leju-digest
TASK_TIME=20:00
TIME_ZONE=Taipei Standard Time

REPORT_ROOT=vault/2-actions/scheduled-reports/a7-leju
STATE_PATH=vault/2-actions/scheduled-reports/a7-leju/state.json
SYNC_LEDGER_PATH=system/skills/local-scheduler/config/sync-ledger.json
AREA_CONFIG_PATH=scripts/a7-line-monitor/area-config.json
BARGAIN_WATCH_CONFIG_PATH=scripts/a7-line-monitor/bargain-watch-config.json
MARKET_PULSE_CONFIG_PATH=scripts/a7-line-monitor/market-pulse-config.json

# LINE sending cadence
# The workflow can still run daily, but LINE is sent only on WEEKLY_REPORT_DAY
# or when a new pending presale project appears.
LINE_SCHEDULE=weekly
# ISO weekday: Monday=1 ... Saturday=6 ... Sunday=7
WEEKLY_REPORT_DAY=6
URGENT_PENDING_PRESALE_ALERT=true

# LINE Messaging API
# Official reference:
# https://developers.line.biz/en/reference/messaging-api/#send-push-message
LINE_CHANNEL_ACCESS_TOKEN=
LINE_MODE=broadcast
LINE_TO=

# LINE_TO is usually a userId, groupId, or roomId.
# Your LINE Official Account must be able to push to that target.
# If LINE_MODE=broadcast, LINE_TO can stay empty and the message will be sent
# to all friends of the LINE Official Account.
