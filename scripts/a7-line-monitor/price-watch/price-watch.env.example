# Copy this file to price-watch.env and fill in secrets.

TASK_ID=price-watch
TASK_TIME=09:00
TASK_INTERVAL_MINUTES=60
TIME_ZONE=Taipei Standard Time

PRICE_WATCH_CONFIG_PATH=scripts/price-watch/price-watch-config.json
PRICE_WATCH_DB_PATH=vault/2-actions/scheduled-reports/price-watch/price-history.sqlite
REPORT_ROOT=vault/2-actions/scheduled-reports/price-watch
FETCH_TIMEOUT_SECONDS=30

# Optional: fetch watches added from the mobile web app.
# Example: https://your-domain.example.com/api/price-watch/watches
PRICE_WATCH_REMOTE_URL=
PRICE_WATCH_ACCESS_TOKEN=

# Product search and legacy fixed-date Google Flights.
SERPAPI_API_KEY=

# Flexible date / annual-low flight search.
SKYSCANNER_API_KEY=

# LINE Messaging API
# LINE_MODE=broadcast sends to all friends of the LINE Official Account.
# LINE_MODE=push sends to LINE_TO only.
LINE_CHANNEL_ACCESS_TOKEN=
LINE_MODE=broadcast
LINE_TO=
